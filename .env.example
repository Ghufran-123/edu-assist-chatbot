# ============================================================
# EDU Assist — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

HUGGINGFACE_TOKEN=your_huggingface_token_here

# --- MongoDB ---
MONGO_URI=mongodb://localhost:27017
DB_NAME=FAQ_AGENT
FAQ_COLLECTION=FAQs

# --- Paths ---
DOCUMENT_FOLDER=data/documents
VECTOR_DB_FOLDER=data/vectorstore
URLS_FILE=config/urls.txt
BASE_DOMAIN=kiet.edu.pk

# --- LLM Model ---
LLM_MODEL=meta-llama/Llama-3.2-1B-Instruct
LLM_MAX_TOKENS=256
LLM_TEMPERATURE=0.0

# --- Pipeline ---
BUILD_INDEX_ON_START=1
FORCE_REINDEX=0
LOG_LEVEL=INFO
DEBUG_MODE=0

# --- Security ---
ADMIN_API_KEY=change_this_to_a_strong_random_key
# CORS_ORIGINS=*
